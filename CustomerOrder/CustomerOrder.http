  "firstName": "John",
  "lastName": "Doe Jr.",
  "phoneNumber": "555-0199",
  "address": "999 Updated St, New York, NY 10002"
}

### 10. Update Customer - Not Found
PUT {{CustomerOrder_HostAddress}}/api/customers/notfound@example.com
Content-Type: application/json
Authorization: Bearer {{token}}

