@CustomerOrder_HostAddress = http://localhost:5044
@AuthService_HostAddress = http://localhost:5170

### ========================================
### AUTHENTICATION
### ========================================
### IMPORTANT: Run this first to get JWT token, then copy the token below
### Or manually set @token variable with your JWT token

### 0. Login to get JWT Token
# @name login
POST {{AuthService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "john.doe@example.com",
  "password": "password123"
}

### After running the login request above, copy the token from response and paste it below
### Or if using VS Code REST Client, it will auto-capture from the response above
@token = YOUR_JWT_TOKEN


### ========================================
### CUSTOMER ENDPOINTS
### ========================================

### 1. Create Customer - John Doe
POST {{CustomerOrder_HostAddress}}/api/customers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "email": "john.doe@example.com",
  "firstName": "John",
  "lastName": "Doe",
  "phoneNumber": "555-0100",
  "address": "123 Main St, New York, NY 10001"
}

### 2. Create Customer - Jane Smith
POST {{CustomerOrder_HostAddress}}/api/customers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "email": "jane.smith@example.com",
  "firstName": "Jane",
  "lastName": "Smith",
  "phoneNumber": "555-0101",
  "address": "456 Oak Ave, Los Angeles, CA 90001"
}

### 3. Create Customer - Bob Johnson
POST {{CustomerOrder_HostAddress}}/api/customers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "email": "bob.johnson@example.com",
  "firstName": "Bob",
  "lastName": "Johnson",
  "phoneNumber": "555-0102",
  "address": "789 Pine Rd, Chicago, IL 60601"
}

### 4. Create Customer - Validation Error (Invalid Email)
POST {{CustomerOrder_HostAddress}}/api/customers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "email": "invalid-email",
  "firstName": "Invalid",
  "lastName": "User"
}

### 5. Create Customer - Validation Error (Missing Required Fields)
POST {{CustomerOrder_HostAddress}}/api/customers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "email": "missing@example.com"
}

### 6. Get All Customers
GET {{CustomerOrder_HostAddress}}/api/customers
Authorization: Bearer {{token}}

### 7. Get Customer by Email - John Doe
GET {{CustomerOrder_HostAddress}}/api/customers/john.doe@example.com
Authorization: Bearer {{token}}

### 8. Get Customer by Email - Not Found
GET {{CustomerOrder_HostAddress}}/api/customers/notfound@example.com
Authorization: Bearer {{token}}

### 9. Update Customer - John Doe
PUT {{CustomerOrder_HostAddress}}/api/customers/john.doe@example.com
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "firstName": "John",
  "lastName": "Doe Jr.",
  "phoneNumber": "555-0199",
  "address": "999 Updated St, New York, NY 10002"
}

### 10. Update Customer - Not Found
PUT {{CustomerOrder_HostAddress}}/api/customers/notfound@example.com
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "firstName": "Not",
  "lastName": "Found",
  "phoneNumber": "555-9999"
}

### 11. Delete Customer (Run this last - deletes Bob Johnson)
DELETE {{CustomerOrder_HostAddress}}/api/customers/bob.johnson@example.com
Authorization: Bearer {{token}}

### 12. Delete Customer - Not Found
DELETE {{CustomerOrder_HostAddress}}/api/customers/notfound@example.com
Authorization: Bearer {{token}}


