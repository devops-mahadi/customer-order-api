# Set default behavior to automatically normalize line endings
* text=auto

# Force LF line endings for these file types
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.http text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.config text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.xml text eol=lf
*.txt text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.dll binary
*.exe binary
*.zip binary
*.7z binary
*.tar binary
*.gz binary
